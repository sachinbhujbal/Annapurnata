<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".RegisterActivity">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:layout_margin="15dp"
        android:padding="15dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/register_head"
            android:textColor="@color/black"
            android:text="@string/register_head"
            android:textAppearance="@style/TextAppearance.AppCompat.Headline"
            android:layout_centerHorizontal="true"
            android:textAlignment="center">

        </TextView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/name_id"
            android:layout_below="@+id/register_head"
            android:text="Full Name*:"
            android:textColor="#555555"
            android:layout_marginTop="50dp"
            android:textSize="16dp"
            android:padding="6dp">
        </TextView>

        <EditText
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/edit_fullName"
            android:inputType="textPersonName"
            android:layout_below="@+id/name_id"
            android:hint="Enter Your Full Name"
            android:layout_marginTop="8dp"
            android:padding="8dp"
            android:textSize="16sp"
            android:background="@drawable/border">
        </EditText>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/email_id"
            android:layout_below="@+id/edit_fullName"
            android:text="Email*:"
            android:textColor="#555555"
            android:layout_marginTop="10dp"
            android:textSize="16dp"
            android:padding="6dp">
        </TextView>

        <EditText
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/edit_Email"
            android:inputType="textEmailAddress"
            android:layout_below="@+id/email_id"
            android:hint="Enter Your Email"
            android:layout_marginTop="8dp"
            android:padding="8dp"
            android:textSize="16sp"
            android:background="@drawable/border">
        </EditText>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/birth_id"
            android:layout_below="@+id/edit_Email"
            android:text="Birth Date (DD/MM/YYYY)*:"
            android:textColor="#555555"
            android:layout_marginTop="10dp"
            android:textSize="16dp"
            android:padding="6dp">
        </TextView>

        <EditText
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/edit_Birth"
            android:inputType="date"
            android:layout_below="@+id/birth_id"
            android:hint="Select Your Birth Date"
            android:layout_marginTop="8dp"
            android:padding="8dp"
            android:textSize="16sp"
            android:background="@drawable/border"
            android:focusable="false">
        </EditText>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/gender_id"
            android:layout_below="@+id/edit_Birth"
            android:text="Gender:"
            android:textColor="#555555"
            android:layout_marginTop="10dp"
            android:textSize="16dp"
            android:padding="6dp">
        </TextView>

        <RadioGroup
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:id="@+id/radio_id"
            android:layout_below="@+id/gender_id">
            <RadioButton
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Male"
                android:textColor="#555555"
                android:padding="6dp"
                android:textSize="16dp"
                android:id="@+id/male_id">

            </RadioButton>
            <RadioButton
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Female"
                android:textColor="#555555"
                android:layout_marginLeft="20dp"
                android:padding="6dp"
                android:textSize="16dp"
                android:id="@+id/female_id">
            </RadioButton>


        </RadioGroup>


        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/mobile_id"
            android:layout_below="@+id/radio_id"
            android:text="Enter Register Mobile*"
            android:textColor="#555555"
            android:layout_marginTop="10dp"
            android:textSize="16dp"
            android:padding="6dp">
        </TextView>

        <EditText
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/edit_Mobile"
            android:inputType="phone"
            android:layout_below="@+id/mobile_id"
            android:hint="Enter Your Mobile Number"
            android:layout_marginTop="8dp"
            android:padding="8dp"
            android:textSize="16sp"
            android:background="@drawable/border">
        </EditText>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/password_id"
            android:layout_below="@+id/edit_Mobile"
            android:text="Enter Password*"
            android:textColor="#555555"
            android:layout_marginTop="10dp"
            android:textSize="16dp"
            android:padding="6dp">
        </TextView>

        <EditText
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/edit_Password"
            android:inputType="textPassword"
            android:layout_below="@+id/password_id"
            android:hint="Enter Your Password"
            android:layout_marginTop="8dp"
            android:padding="8dp"
            android:textSize="16sp"
            android:background="@drawable/border">
        </EditText>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/Repassword_id"
            android:layout_below="@+id/edit_Password"
            android:text="Confirm Password*"
            android:textColor="#555555"
            android:layout_marginTop="10dp"
            android:textSize="16dp"
            android:padding="6dp">
        </TextView>

        <EditText
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/Reedit_Password"
            android:inputType="textPassword"
            android:layout_below="@+id/Repassword_id"
            android:hint="Enter Your Re-Password"
            android:layout_marginTop="8dp"
            android:padding="8dp"
            android:textSize="16sp"
            android:background="@drawable/border">
        </EditText>

        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/register_btn"
            android:text="Register"
            android:layout_below="@+id/Reedit_Password"
            android:layout_marginTop="50dp"
            android:background="@drawable/btn_border"
            android:layout_marginLeft="70dp"
            android:layout_marginRight="70dp"
            android:layout_marginBottom="12dp"
            android:textColor="@color/white">
        </Button>

        <ProgressBar
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:elevation="10dp"
            android:layout_centerHorizontal="true"
            android:layout_centerVertical="true"
            android:id="@+id/progress_circular"
            android:visibility="gone">

        </ProgressBar>


    </RelativeLayout>

</ScrollView>